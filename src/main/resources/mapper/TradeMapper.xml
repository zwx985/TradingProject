<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.laoz.trading.project.mapper.TradeMapper">
    <select id="allList" resultType="com.laoz.trading.project.entity.TradeEntity">
        select id,
               amount,
               create_time,
               update_time
        from T_TRADE
